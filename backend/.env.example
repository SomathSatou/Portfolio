# Copier ce fichier en .env et remplir les valeurs
# cp .env.example .env

# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de données (SQLite par défaut en dev) ────────────────────────────────
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=portfolio
# DB_USER=portfolio_user
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=3306

# ── Email (console en dev si vide, SMTP en prod si renseigné) ─────────────────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=noreply@automia.org
CONTACT_RECIPIENT=contact@automia.org

# ── CORS (dev : tout ouvert, prod : restreindre) ──────────────────────────────
# CORS_ALLOWED_ORIGINS=https://automia.org
